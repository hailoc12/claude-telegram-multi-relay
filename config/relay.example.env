# relay.env — copy to ~/.claude/ccc-orchestrator/relay.env and fill in.
# All values are OPTIONAL; defaults are sensible for a standard ccc setup.
# This file is read by scripts/relay.sh and scripts/run-scheduled.sh.

# Path to the ccc binary (Claude Code Companion).
# Default: "ccc" (assumed on PATH). Override if you keep it elsewhere.
#CCC_BIN="/usr/local/bin/ccc"

# Orchestrator data dir: holds registry.json, schedules.json, logs/
# Default: $HOME/.claude/ccc-orchestrator
#ORCH_DIR="$HOME/.claude/ccc-orchestrator"

# ccc config path (the relay engine config with bot_token + sessions)
# Default: $HOME/.config/ccc/config.json
#CCC_CONFIG="$HOME/.config/ccc/config.json"

# Base directory where new sessions create their working folders.
# This mirrors `ccc config projects-dir`. Quote it if it contains spaces.
# Default: $HOME/Library/Mobile Documents/com~apple~CloudDocs/Documents/9. active
#PROJECTS_DIR="$HOME/Library/Mobile Documents/com~apple~CloudDocs/Documents/9. active"

# PATH injected into the launchd bridge (cron/launchd have minimal PATH).
# Default includes Homebrew on Apple Silicon + Intel + system paths.
#BRIDGE_PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# Telegram group id to use as DEFAULT when a session has no per-session group.
# Read from ccc config if omitted.
#DEFAULT_GROUP_ID="-100xxxxxxxxxx"
